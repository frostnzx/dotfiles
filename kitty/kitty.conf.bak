enable_audio_bell no
font_family FiraCode Nerd Font
bold_font auto
italic_font auto
bold_italic_font auto
font_size 13.0

window_padding_width 25
include theme.conf
#background_opacity 0.60
#hide_window_decorations yes
#confirm_os_window_close 0
fullscreen yes


# BEGIN_KITTY_THEME
# Gruvbox Dark Hard
include current-theme.conf
# END_KITTY_THEME

shell zsh -l

